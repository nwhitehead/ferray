{
  "function": "numpy.polyval",
  "ferrum_function": "ferrum_polynomial::Polynomial::eval",
  "test_cases": [
    {
      "name": "quadratic",
      "inputs": {
        "coefficients": {
          "data": [
            1.0,
            2.0,
            3.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "coefficients_numpy_order": {
          "data": [
            3.0,
            2.0,
            1.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "x": {
          "data": [
            -2.0,
            -1.0,
            0.0,
            1.0,
            2.0
          ],
          "shape": [
            5
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          9.0,
          2.0,
          1.0,
          6.0,
          17.0
        ],
        "shape": [
          5
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    },
    {
      "name": "linear",
      "inputs": {
        "coefficients": {
          "data": [
            2.0,
            3.0
          ],
          "shape": [
            2
          ],
          "dtype": "float64"
        },
        "coefficients_numpy_order": {
          "data": [
            3.0,
            2.0
          ],
          "shape": [
            2
          ],
          "dtype": "float64"
        },
        "x": {
          "data": [
            -2.0,
            -1.0,
            0.0,
            1.0,
            2.0
          ],
          "shape": [
            5
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          -4.0,
          -1.0,
          2.0,
          5.0,
          8.0
        ],
        "shape": [
          5
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    },
    {
