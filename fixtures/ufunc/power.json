{
  "function": "numpy.power",
  "ferrum_function": "ferrum_ufunc::power",
  "test_cases": [
    {
      "name": "standard",
      "inputs": {
        "a": {
          "data": [
            1.0,
            2.0,
            3.0,
            4.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            0.0,
            1.0,
            2.0,
            3.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          1.0,
          2.0,
          9.0,
          64.0
        ],
        "shape": [
          4
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    },
    {
      "name": "fractional",
      "inputs": {
        "a": {
          "data": [
            4.0,
            9.0,
            16.0,
            25.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            0.5,
            0.5,
            0.5,
            0.5
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          2.0,
          3.0,
          4.0,
          5.0
        ],
        "shape": [
          4
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    },
    {
      "name": "negative_exp",
      "inputs": {
        "a": {
          "data": [
            2.0,
            3.0,
            4.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            -1.0,
            -2.0,
            -1.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          0.5,
          0.1111111111111111,
          0.25
        ],
        "shape": [
          3
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    },
    {
      "name": "special",
      "inputs": {
        "a": {
          "data": [
            0.0,
            1.0,
            "Inf",
            "NaN"
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            0.0,
            "Inf",
            0.0,
            1.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          1.0,
          1.0,
          1.0,
          "NaN"
        ],
        "shape": [
          4
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    }
  ]
}