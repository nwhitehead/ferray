{
  "function": "numpy.remainder",
  "ferray_function": "ferray_ufunc::remainder",
  "test_cases": [
    {
      "name": "standard",
      "inputs": {
        "a": {
          "data": [
            7.0,
            8.0,
            9.0,
            10.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            3.0,
            3.0,
            3.0,
            3.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          1.0,
          2.0,
          0.0,
          1.0
        ],
        "shape": [
          4
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    },
    {
      "name": "negative",
      "inputs": {
        "a": {
          "data": [
            -7.0,
            -8.0,
            7.0,
            8.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            3.0,
            -3.0,
            -3.0,
            3.0
          ],
          "shape": [
            4
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          2.0,
          -2.0,
          -2.0,
          2.0
        ],
        "shape": [
          4
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    },
    {
      "name": "float",
      "inputs": {
        "a": {
          "data": [
            5.5,
            6.7,
            8.1
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            2.3,
            2.3,
            2.3
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          0.9000000000000004,
          2.1000000000000005,
          1.2000000000000002
        ],
        "shape": [
          3
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 4
    }
  ]
}