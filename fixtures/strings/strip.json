{
  "function": "numpy.strings.strip",
  "ferrum_function": "ferrum_strings::strip",
  "test_cases": [
    {
      "name": "whitespace",
      "inputs": {
        "x": {
          "data": [
            "  hello  ",
            "\tworld\t",
            "  foo",
            "bar  ",
            "none"
          ],
          "shape": [
            5
          ],
          "dtype": "str"
        }
      },
      "expected": {
        "data": [
          "hello",
          "world",
          "foo",
          "bar",
          "none"
        ],
        "shape": [
          5
        ],
        "dtype": "str"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "with_chars",
      "inputs": {
        "x": {
          "data": [
            "xxhelloxx",
            "xxworldxx"
          ],
          "shape": [
            2
          ],
          "dtype": "str"
        },
        "chars": "x"
      },
      "expected": {
        "data": [
          "hello",
          "world"
        ],
        "shape": [
          2
        ],
        "dtype": "str"
      },
      "tolerance_ulps": 0
    }
  ]
}